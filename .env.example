# Copy this file to `.env.local` and fill in your real values.
# Never commit `.env.local` — it's gitignored.

# Public, safe to expose in browser:
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...

# Server-only — only used inside /api Vercel functions, never exposed to browser:
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
